# Copy to .env for local development
# Fly.io: set these with `fly secrets set KEY=value`

DATABASE_URL=postgresql://user:password@localhost:5432/galabid
ADMIN_PASSWORD=changeme123
PORT=8080
NODE_ENV=development

# Stripe — get these from dashboard.stripe.com
# Use TEST keys (sk_test_...) during dev, swap to live keys on event night
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your Fly.io app URL (used for Stripe redirect URLs)
APP_URL=https://galabid.fly.dev
